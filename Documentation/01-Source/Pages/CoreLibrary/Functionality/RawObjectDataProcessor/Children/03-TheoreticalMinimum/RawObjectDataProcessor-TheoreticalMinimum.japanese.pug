    p.Article-Paragraph.
      #[+ImportantEntity--YDID 「RawObjectDataProcessor」]という名前の直訳から分かる通り、此のユーティリティ#[+Term--YDID クラス]は
        #[+Keyword--YDID オブジェクト型]データ、つまり#[+ImportantEntity--YDID typeof N === "object"]という条件を満たした上で、
        かつ#[+ImportantEntity__Code--YDID null]#[+Keyword--YDID ではない]データを扱う為のものである。
      ところで、#[+Keyphrase--YDID #[+ImportantEntity--YDID ECMAScript]規格の観点では]、
        #[+ImportantEntity__Code--YDID typeof null]#[+Keyword--YDID も]#[+ImportantEntity__Code--YDID "object"]となっている。
      #[+Keyword--YDID 子]#[+Term--YDID プロパティ]なら、数型や文字列や真偽を含めて他の型を持つ事が出来る。
      但し、現時点では#[+Keyphrase--YDID #[+ImportantEntity--YDID JSON]互換のデータ#[+Keyword--YDID のみ]]が
        #[+Keyword--YDID 完全に]サポートされている。
      該当している#[+Term--YDID 型]の定義は以下の通り。

    +CodeViewer--YDF
      +CodeViewer-Listing--YDF({ codeLanguage: CodeViewer__YDF.SupportedCodesLanguages.TypeScript }): :code_listing--yda
        export type ParsedJSON = ParsedJSON_Object | ParsedJSON_Array;

        export type ParsedJSON_Object = { [key: string]: ParsedJSON_NestedProperty; };

        export type ParsedJSON_Array = Array<ParsedJSON_NestedProperty>;

        export type ParsedJSON_NestedProperty =
          number |
          string |
          boolean |
          null |
          ParsedJSON_Object |
          ParsedJSON_Array |
          undefined;

    +AdmonitionBlock--YDF({
      title: "JSONとオブジェクト",
      SVG_Icon: true,
      areThemesCSS_ClassesCommon: true,
      geometricVariation: AdmonitionBlock__YDF.GeometricVariations.stickyNoteLike,
      decorativeVariation: AdmonitionBlock__YDF.DecorativeVariations.warning

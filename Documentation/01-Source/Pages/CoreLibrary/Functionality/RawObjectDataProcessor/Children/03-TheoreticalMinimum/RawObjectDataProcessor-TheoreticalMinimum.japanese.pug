    p.Article-Paragraph.
      此の型の#[+Term--YDID オブジェクト]は、#[+Keyword--YDID 最も]#[+Keyword__Contrast--YDID 一般的]である。
      クライアントとサーバー間等で送受信されるシリアライズされたデータは、殆どの場合此の形式。
      #[+ImportantEntity--YDID JSON]や#[+ImportantEntity--YDID YAML]形式等のファイルに保存される設定も、通常はこの形式である
        （例えば#[+SecondaryEntity--YDID TypeScript]の設定ファイルの#[+SecondaryEntity__Code--YDID tsconfig.json]）。


    //- ╍╍╍ 連想配列 ╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍╍
    +Heading--YDF({
      level: 3,
      text: localizedSectioning.objectLikeDataClassification.$children.associativeArrays.$heading,
      HTML_ID: localizedSectioning.objectLikeDataClassification.$children.associativeArrays.$anchor
    }).Article-Heading3

    p.Article-Paragraph.
      #[+Term--YDID 連想配列]は、#[+Term--YDID 固定構造オブジェクト]とは異なり、#[+Term--YDID プロパティ]名が#[+Keyword--YDID 事前に]
        分かっておらず、要素数も#[+ImportantEntity__Code--YDID 0]から最大整数範囲内ならいくらでも有り得る。

    p.Article-Paragraph.
      #[+ImportantEntity--YDID ESMAScript 2015]規格#[+Keyword--YDID 以前]は、此の様な#[+Term--YDID 配列]として
        #[+Keyword--YDID 通常の]#[+Term--YDID オブジェクト]が使用されていた。
      #[+Keyphrase--YDID #[+Keyword--YDID 出力]#[+Term--YDID JavaScriptコード]の観点では]、#[+Term--YDID 固定構造オブジェクト]と何ら
        #[+Keyword--YDID 変わりない]。
      #[+ImportantEntity--YDID TypeScript]では、こうした#[+Term--YDID 連想配列]は以下の#[+Keyphrase--YDID 何れかのの]方法で
        アノテーションされる。

    +CodeViewer--YDF
      +CodeViewer-Listing--YDF({ codeLanguage: CodeViewer__YDF.SupportedCodesLanguages.TypeScript }): :code_listing--yda
        type AssociativeArray<ValueType> = { [ key: string ]: ValueType };

        // 又は

        type AssociativeArray<ValueType> = Record<string, ValueType>;

    p.Article-Paragraph.
      #[+ImportantEntity--YDID ESMAScript 2015]#[+Term--YDID 規格]で導入された#[+ImportantEntity--YDID Map]
        #[+Term--YDID データ型]を#[+Term--YDID 連想配列]と呼ぶかどうかは、其の#[+Term--YDID 配列]が#[+Keyword--YDID 何れでもの]型の
        #[+Term__Contrast--YDID キー]を許容するかどうかに依存する。
      特に#[+ImportantEntity--YDID Map]は#[+Term--YDID オブジェクト型]の#[+Term--YDID キー]を禁止#[+Keyword--YDID していない]。
      何れにせよ、#[+ImportantEntity--YDID Map型]は#[+ImportantEntity--YDID JSON]と互換性が#[+Keyword--YDID ない]。
      然し、#[+ImportantEntity--YDID Map]を#[+Keyword--YDID 二次元]の#[+Term--YDID インデックス配列]に変換する事で、互換性を持たせる事が出来る。
      此の場合、#[+Keyword--YDID 各]#[+Keyword__Contrast--YDID 子]#[+Term--YDID 配列]の#[+Keyword--YDID 1番目]の
        #[+Term--YDID 要素]を#[+Term--YDID キー]、#[+Keyword--YDID 2番目]の#[+Term--YDID 要素]を#[+Term--YDID 値]とする。

    +CodeViewer--YDF
      +CodeViewer-Listing--YDF({ codeLanguage: CodeViewer__YDF.SupportedCodesLanguages.TypeScript }): :code_listing--yda
        const sampleMap: Map<string, number> = new Map([
          [ "alpha", 1 ],
          [ "bravo", 2 ],
          [ "charlie", 3 ]
        ]);

        const serializedMap: string = JSON.stringify(Array.from(sampleMap.entries()));

    +AdmonitionBlock--YDF({

{
  "name": "@yamato-daiwa/es-extensions",
  "version": "1.9.0-alpha.5",
  "description": "Helper functions and classes aimed to reduce the routine code. Build-in TypeScript type safety.",
  "keywords": [
    "typescript",
    "utils",
    "logger"
  ],
  "author": {
    "name": "Takeshi Tokugawa",
    "email": "tokugawa.takesi@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://ee.yamato-daiwa.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TokugawaTakeshi/Yamato-Daiwa-ES-Extensions.git"
  },
  "bugs": {
    "url": "https://github.com/TokugawaTakeshi/Yamato-Daiwa-ES-Extensions.git/issues",
    "email": "tokugawa.takesi@gmail.com"
  },
  "main": "./Distributable/cjs/index.js",
  "module": "./Distributable/esm/index.js",
  "types": "./Distributable/esm/index.d.ts",
  "sideEffects": false,
  "files": [
    "Distributable"
  ],
  "dependencies": {
    "fundamental-constants": "0.9.0"
  },
  "devDependencies": {
    "@types/node": "22.15.31",
    "@yamato-daiwa/style_guides": "0.14.3",
    "rimraf": "6.1.3",
    "timezone-mock": "1.4.3",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  },
  "scripts": {
    "Check Types": "tsc -p tsconfig-cjs.json --noEmit",
    "Lint": "eslint",
    "Run Tests": "node --require tsx/cjs --test \"Tests/Automated/**/*.test.ts\"",
    "Rebuild Distributable Without Preliminary Cleaning": "tsc -p tsconfig-cjs.json && tsc -p tsconfig-esm.json",
    "Rebuild Distributable": "rimraf --glob Distributable/* && tsc -p tsconfig-cjs.json && tsc -p tsconfig-esm.json",
    "Rebuild Distributable and Realize Alpha": "npm run \"Rebuild Distributable\" && npm publish --tag alpha",
    "Rebuild Distributable and Realize RC": "npm run \"Rebuild Distributable\" && npm publish --tag rc"
  },
  "funding": "https://github.com/TokugawaTakeshi/Yamato-Daiwa-ES-Extensions?sponsor=1"
}
